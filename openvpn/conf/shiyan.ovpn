client
proto udp
remote 120.202.94.224 1194
dev tun
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
verify-x509-name server_qvgfhqn4aZPseqoP name
auth SHA256
auth-user-pass /etc/openvpn/auth
cipher AES-128-GCM
tls-client
tls-version-min 1.2
tls-cipher TLS-ECDHE-ECDSA-WITH-AES-128-GCM-SHA256
verb 3

explicit-exit-notify


## Custom configuration ##
route 172.30.0.0 255.255.0.0
## end ##

